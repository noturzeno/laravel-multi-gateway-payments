RECON_LANGUAGE=en
RECON_AMOUNT=15000
RECON_DESCRIPTION="This is a 24 monthsIPPexample."
RECON_TIMEOUT=20
RECON_VERSION=1
RECON_USE_PRODUCTION=false
RECON_TESTING_URL=https://secure-uat.reconpayment.com/ws/b2cPay
RECON_PRODUCTION_URL=https://secure.reconpayment.com/ws/b2cPay

